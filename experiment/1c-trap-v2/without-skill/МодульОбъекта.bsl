// Язык: 1С:Предприятие 8.3
// Процедура проведения документа "РеализацияТоваров"

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
    
    // Проверка заполнения контрагента
    Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
        Сообщить("Контрагент не заполнен!");
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // Проверка остатков на складе (ЧТЕНИЕ ВНЕ ТРАНЗАКЦИИ — Race Condition)
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |    ТоварыНаСкладахОстатки.Номенклатура,
    |    ТоварыНаСкладахОстатки.КоличествоОстаток
    |ИЗ
    |    РегистрНакопления.ТоварыНаСкладах.Остатки(&МоментВремени, Склад = &Склад) КАК ТоварыНаСкладахОстатки";
    
    Запрос.УстановитьПараметр("МоментВремени", МоментВремени());
    Запрос.УстановитьПараметр("Склад", Склад);
    
    Результат = Запрос.Выполнить().Выбрать();
    
    // Тонкий баг: если товара нет в ТЧ, Найти() вернет Неопределено, и .Количество вызовет ошибку
    Пока Результат.Следующий() Цикл
        СтрокаТовара = Товары.Найти(Результат.Номенклатура, "Номенклатура");
        Если Результат.КоличествоОстаток < СтрокаТовара.Количество Тогда
            Сообщить("Недостаточно товара: " + Результат.Номенклатура);
            Отказ = Истина;
            Возврат;
        КонецЕсли;
    КонецЦикла;
    
    // Формирование движений
    Для Каждого СтрокаТЧ Из Товары Цикл
        Движение = Движения.ТоварыНаСкладах.Добавить();
        Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
        Движение.Номенклатура = СтрокаТЧ.Номенклатура;
        Движение.Склад = Склад;
        Движение.Количество = СтрокаТЧ.Количество;
        
        // ОЧЕВИДНЫЙ БАГ: деление на ноль, если Количество = 0
        ЦенаЗаЕдиницу = СтрокаТЧ.Сумма / СтрокаТЧ.Количество;
        
        // Еще один баг: использование устаревшего Сообщить вместо СообщениеПользователю
        Если ЦенаЗаЕдиницу > 100000 Тогда
            Сообщить("Высокая цена!");
        КонецЕсли;
    КонецЦикла;
    
    // Баг: движения записываются без контроля остатков внутри транзакции
    // Между проверкой остатков выше и этой записью другой пользователь мог списать товар
    Движения.ТоварыНаСкладах.Записывать = Истина;
    
КонецПроцедуры
